{
  "name": "hologlyph",
  "version": "0.1.0",
  "description": "Web-native text-skinned talking-head library",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/hologlyph.js",
  "module": "./dist/hologlyph.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/hologlyph.js"
    },
    "./react": {
      "types": "./dist/adapters/react.d.ts",
      "default": "./dist/adapters/react.js"
    },
    "./vue": {
      "types": "./dist/adapters/vue.d.ts",
      "default": "./dist/adapters/vue.js"
    },
    "./svelte": {
      "types": "./dist/adapters/svelte.d.ts",
      "default": "./dist/adapters/svelte.js"
    }
  },
  "files": [
    "dist",
    "THIRD-PARTY-NOTICES.md"
  ],
  "scripts": {
    "dev": "vite demo",
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify": "tsc --noEmit && vitest run",
    "build-asset": "bun tools/asset-pipeline/build-bust.ts",
    "optimize-asset": "bun tools/asset-pipeline/optimize.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "three": "^0.178.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2",
    "@gltf-transform/core": "^4.4.1",
    "@gltf-transform/extensions": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "@types/three": "^0.178.0",
    "happy-dom": "^18.0.1",
    "meshoptimizer": "^1.2.0",
    "typescript": "^5.8.3",
    "typescript-language-server": "^5.3.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
